// https://yalter.github.io/niri/Configuration:-Introduction

input {

    mod-key "Alt"
    mod-key-nested "Alt"

    keyboard {
        xkb {
{{ if .SwapEscape }}
            options "caps:swapescape"
{{ end }}
        layout "us"
        }
        numlock
    }

    touchpad {
        tap
        // natural-scroll
        middle-emulation
        dwt
    }

    mouse {
        accel-profile "flat"
{{ if hasKey . "mouse_id" }}
        accel-speed 0.7
{{ else }}
        accel-speed 1.0
{{ end }}
    }
}

// ── Outputs ───────────────────────────────────────────────────────────────────

{{ if eq .chezmoi.hostname "sb-desktop" }}
output "DP-3" {
    // $top
    mode "2560x1440"
    position x=0 y=0
}

output "DP-1" {
    // $primary
    mode "1920x1080@240"
    position x=2560 y=0
}

output "DP-2" {
    // $right
    mode "2560x1440"
    position x=4480 y=0
}
{{ end }}

// ── Layout ───────────────────────────────────────────────────────────────────

layout {
    gaps 8

    focus-ring {
        width 2
        active-color "#bd93f9"    // Dracula purple
        inactive-color "#44475a"  // Dracula comment
    }

    border {
        off
    }

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }
}

// ── Animations ────────────────────────────────────────────────────────────────

animations {
    // Uncomment to disable all animations:
    // off
}

// ── Screenshot path ───────────────────────────────────────────────────────────

screenshot-path "~/Pictures/screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// ── Startup programs ──────────────────────────────────────────────────────────

// spawn-at-startup "sh" "-c" "gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'"
// spawn-at-startup "sh" "-c" "gsettings set org.gnome.desktop.interface gtk-theme 'Dracula' && gsettings set org.gnome.desktop.interface icon-theme 'Dracula' && gsettings set org.gnome.desktop.wm.preferences theme 'Dracula'"

// Input remapper
spawn-at-startup "input-remapper-control" "--command" "autoload"

// Clipboard manager
spawn-at-startup "copyq" "--start-server"

{{ if eq .chezmoi.hostname "sb-desktop" }}
// GoXLR daemon
spawn-at-startup "goxlr-daemon"

// XWayland primary output workaround for games
spawn-at-startup "sh" "-c" "xrandr --output DP-1 --primary --mode 1920x1080 --rate 240"
{{ end }}

{{ if ne .chezmoi.hostname "prothean" }}
// KDE Connect daemon
spawn-at-startup "/usr/bin/kdeconnectd"
{{ end }}

// ── Window rules ──────────────────────────────────────────────────────────────

// Firefox Picture-in-Picture — floating
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id="com.github.hluk.copyq"
    open-floating true
    default-column-width { fixed 550; }
}

// ── Key bindings ──────────────────────────────────────────────────────────────

binds {
    // Show hotkey overlay
    Mod+Shift+Slash { show-hotkey-overlay; }

{{ if lookPath "ghostty" }}
    Mod+Return hotkey-overlay-title="Open a Terminal: ghostty" { spawn "{{ output "which" "ghostty" | trim }}"; }

{{ else }}
    Mod+Return { spawn "foot"; }
{{ end }}

    Mod+D hotkey-overlay-title="Run an Application: fuzzel" { spawn "fuzzel" "-i" "--hide-before-typing" "-l" "3"; }

    // Kill focused window — $mod+q
    Mod+Q repeat=false { close-window; }

    // CopyQ toggle — $mod+c
    Mod+C { spawn "copyq" "toggle"; }

    // Network manager dmenu — $mod+Ctrl+n
    Mod+Ctrl+N { spawn "/home/scott/.local/scripts/networkmanager_dmenu"; }

    // Exit niri — $mod+Shift+e
    Mod+Shift+E { quit; }

    // Power off — $mod+Shift+s
    Mod+Shift+S { spawn "systemctl" "poweroff" "-i"; }


{{ if eq .chezmoi.hostname "sb-desktop" }}
    // Toggle speakers/headphones — F12 (sb-desktop only)
    F12 { spawn "/home/scott/.local/scripts/audio_toggle.sh"; }
{{ end }}

    // ── Focus (vim keys + arrows) ─────────────────────────────────────────────
    Mod+H     { focus-column-left; }
    Mod+J     { focus-window-down; }
    Mod+K     { focus-window-up; }
    Mod+L     { focus-column-right; }
    Mod+Left  { focus-column-left; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }
    Mod+Right { focus-column-right; }

    // ── Move windows ──────────────────────────────────────────────────────────
    Mod+Shift+H     { move-column-left; }
    Mod+Shift+J     { move-window-down; }
    Mod+Shift+K     { move-window-up; }
    Mod+Shift+L     { move-column-right; }
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Down  { move-window-down; }
    Mod+Shift+Up    { move-window-up; }
    Mod+Shift+Right { move-column-right; }

    // ── Focus monitors ────────────────────────────────────────────────────────
    Mod+Ctrl+Shift+H     { focus-monitor-left; }
    Mod+Ctrl+Shift+J     { focus-monitor-down; }
    Mod+Ctrl+Shift+K     { focus-monitor-up; }
    Mod+Ctrl+Shift+L     { focus-monitor-right; }

    // ── Move columns to monitors ──────────────────────────────────────────────
    Mod+Shift+Ctrl+Left     { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down     { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up     { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right     { move-column-to-monitor-right; }

    // ── Workspaces ────────────────────────────────────────────────────────────
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+0 { focus-workspace 10; }

{{ if eq .chezmoi.hostname "sb-desktop" }}
    // On desktop: move container AND follow cursor to the new workspace (multi-monitors)
    Mod+Shift+1 { move-column-to-workspace 1; focus-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; focus-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; focus-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; focus-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; focus-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; focus-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; focus-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; focus-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; focus-workspace 9; }
    Mod+Shift+0 { move-column-to-workspace 10; focus-workspace 10; }
{{ else }}
    // On other machines: move container without following
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }
    Mod+Shift+0 { move-column-to-workspace 10; }
{{ end }}

    Mod+Page_Down { focus-workspace-down; }
    Mod+Page_Up   { focus-workspace-up; }
    Mod+U         { focus-workspace-down; }
    Mod+I         { focus-workspace-up; }

    // ── Layout ────────────────────────────────────────────────────────────────

    // Fullscreen — $mod+f / $mod+Shift+f
    Mod+F       { maximize-column; }
    Mod+Shift+F { fullscreen-window; }

    // Float toggle — $mod+Shift+space
    Mod+Shift+Space { toggle-window-floating; }

    // Switch focus between floating and tiling — $mod+space
    Mod+Space { switch-focus-between-floating-and-tiling; }

    Mod+W { toggle-column-tabbed-display; }

    Mod+R         { switch-preset-column-width; }
    Mod+Shift+R   { switch-preset-window-height; }
    Mod+Minus     { set-column-width "-10%"; }
    Mod+Equal     { set-column-width "+10%"; }
    Mod+Shift+Minus { set-window-height "-10%"; }
    Mod+Shift+Equal { set-window-height "+10%"; }

    Mod+A { center-column; }

    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+V            { consume-window-into-column; }
    Mod+B            { expel-window-from-column; }

    // Overview
    Mod+O repeat=false { toggle-overview; }

    Mod+Shift+P { power-off-monitors; }

    // Keyboard shortcuts inhibit escape hatch
    Mod+Escape allow-inhibiting=false { toggle-keyboard-shortcuts-inhibit; }

    // ── Screenshots ───────────────────────────────────────────────────────────
    Print      { screenshot-screen; }
    Ctrl+Print { screenshot; }
    Alt+Print  { screenshot-window; }

    // ── Volume ────────────────────────────────────────────────────────────────
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "pactl set-sink-volume @DEFAULT_SINK@ +10%"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "pactl set-sink-volume @DEFAULT_SINK@ -10%"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "pactl set-sink-mute @DEFAULT_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "pactl set-source-mute @DEFAULT_SOURCE@ toggle"; }

    // ── Brightness ────────────────────────────────────────────────────────────
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "set" "+5%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "set" "5%-"; }
}

include "dms/colors.kdl"
include "dms/layout.kdl"
include "dms/alttab.kdl"
include "dms/binds.kdl"
include "dms/cursor.kdl"
